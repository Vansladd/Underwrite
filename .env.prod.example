# Copy to .env on the box (chmod 600). Never baked into an image. See D-016.

# --- Container image --------------------------------------------------------
# ECR tag to run, e.g. 564250611758.dkr.ecr.eu-west-2.amazonaws.com/underwrite/api:<sha>
API_IMAGE=

# --- Database ---------------------------------------------------------------
# No host port in prod; postgres is reachable on the container network only.
POSTGRES_USER=underwrite
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=underwrite
DATABASE_URL=postgresql+asyncpg://underwrite:change-me-strong@db:5432/underwrite

# --- API --------------------------------------------------------------------
# Public hostname Caddy serves + requests a cert for (UW-067). localhost = internal cert.
DOMAIN=underwrite.nexusstechnologies.com
QUOTE_BASE_URL=https://underwrite.nexusstechnologies.com

# --- Auth (UW-019) — the deployed URL has proper auth, not a public password. See D-026.
# `openssl rand -hex 32`. Rotating it invalidates every live session.
SECRET_KEY=change-me-to-a-32-byte-random-hex
# On: the session cookie is Secure (served over TLS).
SESSION_SECURE=1
# A strong, PRIVATE password shared with reviewers directly — never the public default.
SEED_OPERATOR_USERNAME=demo
SEED_OPERATOR_PASSWORD=change-me-to-a-strong-secret

# --- External services ------------------------------------------------------
ANTHROPIC_API_KEY=
COMPANIES_HOUSE_API_KEY=

# --- PDF rendering & storage ------------------------------------------------
# 0 in prod: the API image carries no WeasyPrint deps; rendering is the Lambda (UW-051).
LOCAL_PDF=0
# S3 bucket for generated PDFs — REQUIRED in prod so the API serves presigned S3 URLs (where the
# render Lambda writes). Empty falls back to local disk, which won't see the Lambda's output.
# `terraform output documents_bucket`.
DOCUMENTS_BUCKET=underwrite-documents-564250611758

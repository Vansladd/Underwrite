# Copy to .env (`make .env` does this). No key here is needed for `make up`.

# --- Database ---------------------------------------------------------------
POSTGRES_USER=underwrite
POSTGRES_PASSWORD=underwrite
POSTGRES_DB=underwrite
# Host port only, kept off 5432 to avoid collisions. In-network it is 5432.
POSTGRES_PORT=55432
DATABASE_URL=postgresql+asyncpg://underwrite:underwrite@db:5432/underwrite

# --- API --------------------------------------------------------------------
API_PORT=8000
WEB_PORT=5173
QUOTE_BASE_URL=http://localhost:8000

# --- Auth (UW-019) ----------------------------------------------------------
# Signs the session cookie; rotating it logs everyone out. Set a strong value in prod.
SECRET_KEY=dev-insecure-change-me
# 1 only behind TLS (prod). Off for http://localhost dev.
SESSION_SECURE=0
# The seeded operator. Local default is public; prod sets a strong, private secret. See D-026.
SEED_OPERATOR_USERNAME=demo
SEED_OPERATOR_PASSWORD=underwrite-demo

# --- External services ------------------------------------------------------
# UW-020: https://console.anthropic.com
ANTHROPIC_API_KEY=
# UW-022: https://developer.company-information.service.gov.uk (free, self-serve)
COMPANIES_HOUSE_API_KEY=

# --- PDF rendering ----------------------------------------------------------
# 1 = render in-process with WeasyPrint (no AWS needed). See UW-055.
LOCAL_PDF=1
